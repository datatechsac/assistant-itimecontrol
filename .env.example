# ============================================================
# itimecontrol-assistant — .env.example
# Copia este archivo a .env y completa los valores
# ============================================================

# HuggingFace (para descargar modelos privados o guardar fine-tuning)
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (opcional — para embeddings o comparación de modelos)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutas del proyecto (dejar vacías para usar config.yaml)
BASE_DIR=
DATA_DIR=
MODELS_DIR=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=cambia_esta_clave_secreta

# GPU (número de GPU a usar, -1 para CPU)
CUDA_VISIBLE_DEVICES=0
